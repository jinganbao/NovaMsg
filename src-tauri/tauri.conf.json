{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovaMsg",
  "version": "1.0.1",
  "identifier": "com.sunshine.NovaMsg",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NovaMsg",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4RUEyQUQwN0Q0OTA4MEMKUldRTUNFbDkwQ3JxT1BCeFhVY1pIaEFGMUxSTStEMGtCU3ppa2RzTFJ2OUVrVDlWdEVyUXVCRFQK",
      "endpoints": [
        "https://github.com/jinganbao/NovaMsg/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
